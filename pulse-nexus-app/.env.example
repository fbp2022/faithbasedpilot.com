# Copy this file to .env and fill in real values. .env is gitignored.
# These keys are read at build time via expo-constants.

# ────────────────────────────────────────────────────────────────
# COACH (AI providers)
# ────────────────────────────────────────────────────────────────
# Pulse Nexus's Coach chat can run on any of four providers. The user
# picks which one is active in the in-app Preferences screen. You only
# need to fill in keys for the provider(s) you want to enable; missing
# keys disable that provider with a clear in-app message.

# Google Gemini — FREE TIER available
# https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# OpenAI ChatGPT — paid
# https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude — paid
# https://console.anthropic.com/settings/keys
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-3-5-haiku-latest

# xAI Grok — paid (SuperGrok subscribers may receive API credits)
# https://console.x.ai/
EXPO_PUBLIC_XAI_API_KEY=
EXPO_PUBLIC_XAI_MODEL=grok-2-latest

# ────────────────────────────────────────────────────────────────
# DEVICE INTEGRATIONS
# ────────────────────────────────────────────────────────────────

# WHOOP — no env vars required.
# Pulse Nexus talks to the WHOOP strap directly over Bluetooth, so there is no
# WHOOP account, no OAuth flow, and no subscription. Pair the strap from
# Connect → WHOOP → Pair over Bluetooth. See lib/whoop-ble.ts.

# Fitbit (incl. new Google models & Pixel Watch) — free, self-serve
# https://dev.fitbit.com/apps/new
# Redirect URI to register: pulsenexus://fitbit-callback
EXPO_PUBLIC_FITBIT_CLIENT_ID=
EXPO_PUBLIC_FITBIT_CLIENT_SECRET=

# Garmin Health API — REQUIRES PARTNER APPROVAL
# https://developerportal.garmin.com/
# Redirect URI to register: pulsenexus://garmin-callback
# Leave blank until approved; the app shows an "approval required" state.
EXPO_PUBLIC_GARMIN_CLIENT_ID=
EXPO_PUBLIC_GARMIN_CLIENT_SECRET=
