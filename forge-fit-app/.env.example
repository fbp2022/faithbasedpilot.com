# Copy this file to .env and fill in real values. .env is gitignored.
# These keys are read at build time via expo-constants.

# Google AI Studio key (free tier).
# Get one at: https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# WHOOP developer app credentials. Free, self-serve.
# Register at: https://developer.whoop.com/
# Redirect URI to register with WHOOP: forgefit://whoop-callback
EXPO_PUBLIC_WHOOP_CLIENT_ID=
EXPO_PUBLIC_WHOOP_CLIENT_SECRET=

# Fitbit developer app credentials. Free, self-serve.
# Works for all current Fitbit devices including new Google-era Fitbits
# (Charge 6, Inspire 3, Versa 4, Sense 2) and Pixel Watch.
# Register at: https://dev.fitbit.com/apps/new
# Redirect URI to register with Fitbit: forgefit://fitbit-callback
EXPO_PUBLIC_FITBIT_CLIENT_ID=
EXPO_PUBLIC_FITBIT_CLIENT_SECRET=

# Garmin Health API credentials. REQUIRES PARTNER APPROVAL.
# Apply at: https://developerportal.garmin.com/
# Redirect URI to register with Garmin: forgefit://garmin-callback
# Leave blank until you are approved; the app will display an
# "approval required" message in the Connect tab when blank.
EXPO_PUBLIC_GARMIN_CLIENT_ID=
EXPO_PUBLIC_GARMIN_CLIENT_SECRET=
